{
  "name": "@career-workbench/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:local": "vite --host 0.0.0.0",
    "dev:remote": "vite --host 0.0.0.0 --mode remote",
    "dev:mock": "vite --host 0.0.0.0 --mode mock",
    "check": "pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "test": "node ./scripts/no-tests.mjs",
    "build": "vite build",
    "build:mock": "vite build --mode mock"
  },
  "dependencies": {
    "@assistant-ui/react": "0.14.21",
    "@career-workbench/domain": "workspace:*",
    "@career-workbench/mock": "workspace:*",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@heroui/react": "3.1.0",
    "@heroui/styles": "3.1.0",
    "@internationalized/date": "3.12.2",
    "@supabase/supabase-js": "^2.107.0",
    "lucide-react": "1.17.0",
    "quill": "^2.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "code-inspector-plugin": "^1.5.1",
    "msw": "^2.14.6",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "^7.0.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
