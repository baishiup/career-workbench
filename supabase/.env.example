# Supabase Edge Functions 本地环境变量模板。
# 复制为 supabase/.env.local 后填入真实值；pnpm dev:local / supabase functions serve 会读取该文件。
#
# 约定：每个 Dify workflow 对应一个 App，各自使用独立的 API Key。

# --- 共用 ---
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_USER=career-workbench-debug

# --- 简历附件解析 workflow（upload-resume / complete-onboarding-with-resume）---
DIFY_RESUME_PARSE_API_KEY=
DIFY_RESUME_INPUT_NAME=resume_file

# --- job_parse workflow（job-parse，仅 admin）---
DIFY_JOB_PARSE_API_KEY=

# --- job_match workflow（job-match，登录用户）---
DIFY_JOB_MATCH_API_KEY=

# --- resume_generate workflow（resume-generate，登录用户）---
DIFY_RESUME_GENERATE_API_KEY=
